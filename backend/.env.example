# Example backend settings for local development.
BHA_APP_ENV=development
BHA_DEBUG=true
BHA_API_PREFIX=
BHA_AUTH_SECRET_KEY=development-secret-key
BHA_SQLITE_DB_PATH=data/behavioral_health.sqlite3
# Local stub mode stays on by default. To test against OpenAI, set
# BHA_ASSISTANT_TEST_MODE=false and define OPENAI_API_KEY or
# BHA_ASSISTANT_LLM_API_KEY. If you keep the default stub URL and model,
# the backend will switch to https://api.openai.com and gpt-4.1-mini.
BHA_ASSISTANT_TEST_MODE=true
BHA_ASSISTANT_LLM_BASE_URL=http://127.0.0.1:8001
BHA_ASSISTANT_LLM_API_KEY=
BHA_ASSISTANT_MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0
BHA_ASSISTANT_TIMEOUT_SECONDS=60
BHA_ASSISTANT_INCLUDE_FEWSHOT=true
BHA_ASSISTANT_RECENT_HISTORY_TURNS=5
